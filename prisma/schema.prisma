generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("commerciale")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  quotes    Quote[]
}

model Product {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  block         String
  type          String
  positioning   String
  includes      String
  objection     String?
  response      String?
  price         Int
  priceLabel    String?
  isMonthly     Boolean  @default(false)
  isRecurring   Boolean  @default(false)
  prerequisites String?
  bundleItems   String?
  active        Boolean  @default(true)
  sortOrder     Int      @default(0)
  diagnosiPeso  Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  quotesAsDce   Quote[]  @relation("QuoteDceProduct")
}

model RoiConfig {
  id                    String   @id
  defaultPreventiviMese Float    @default(4)
  defaultImportoMedio   Float    @default(5000)
  defaultConversione    Float    @default(25)
  defaultMargine        Float    @default(20)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Quote {
  id                    String      @id @default(cuid())
  quoteNumber           String      @unique
  userId                String
  dceProductId          String?
  clientName            String
  clientCompany         String?
  clientEmail           String?
  clientPhone           String?
  clientNotes           String?
  crmCustomerId         String?
  clientAddress         String?
  clientPostalCode      String?
  clientCity            String?
  clientProvince        String?
  originCliente         String?
  estrattoDiagnosi      String?
  diagnosiGiaPagata     Boolean     @default(true)
  roiPreventiviMese     Float?
  roiImportoMedio       Float?
  roiConversioneAttuale Float?
  roiMargineCommessa    Float?
  roiSnapshot           String?
  clientVat             String?
  clientSdi             String?
  totalSetup            Int
  totalMonthly          Int
  totalAnnual           Int
  setupBeforeDiscount   Int         @default(0)
  discountType          String?
  discountAmount        Int         @default(0)
  discountCode          String?
  discountPercent       Int         @default(0)
  scontoCrmAnnuale      Boolean     @default(true)
  scontoAiVocaleAnnuale Boolean     @default(false)
  scontoWaAnnuale       Boolean     @default(false)
  voucherAuditApplied   Boolean     @default(false)
  status                String      @default("draft")
  sentAt                DateTime?
  viewedAt              DateTime?
  expiresAt             DateTime?
  notes                 String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  dceProduct            Product?    @relation("QuoteDceProduct", fields: [dceProductId], references: [id])
  user                  User        @relation(fields: [userId], references: [id])
  items                 QuoteItem[]
}

model QuoteItem {
  id          String   @id @default(cuid())
  quoteId     String
  productCode String
  productName String
  price       Int
  quantity    Int      @default(1)
  isMonthly   Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model DiscountCode {
  id              String    @id @default(cuid())
  code            String    @unique
  description     String?
  discountPercent Int       @default(0)
  discountAmount  Int       @default(0)
  maxUses         Int?
  usedCount       Int       @default(0)
  expiresAt       DateTime?
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
