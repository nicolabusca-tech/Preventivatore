{
  "name": "preventivatore-metodo-cantiere",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node node_modules/next/dist/bin/next dev",
    "dev:poll": "CHOKIDAR_USEPOLLING=1 WATCHPACK_POLLING=true node node_modules/next/dist/bin/next dev",
    "build": "prisma generate && prisma migrate deploy && node node_modules/next/dist/bin/next build",
    "start": "node node_modules/next/dist/bin/next start",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "setup": "npm install && prisma db push && npm run db:seed",
    "test:credito": "tsx scripts/test-credito-mc.ts",
    "test:pdf-layout": "tsx scripts/test-pdf-layout.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.19.0",
    "@sparticuz/chromium": "^147.0.2",
    "bcryptjs": "^2.4.3",
    "next": "^14.2.0",
    "next-auth": "^4.24.7",
    "puppeteer": "^24.42.0",
    "puppeteer-core": "^24.42.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.12.0",
    "@types/puppeteer": "^5.4.7",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "prisma": "^5.19.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
