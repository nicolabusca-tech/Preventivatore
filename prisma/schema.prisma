generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("commerciale")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  quotes    Quote[]
}

model Product {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  block         String
  type          String
  positioning   String
  includes      String
  objection     String?
  response      String?
  price         Int
  priceLabel    String?
  isMonthly     Boolean  @default(false)
  isRecurring   Boolean  @default(false)
  prerequisites String?
  bundleItems   String?
  active        Boolean  @default(true)
  sortOrder     Int      @default(0)
  diagnosiPeso  Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  costs         ProductCost[]
  quotesAsDce   Quote[]  @relation("QuoteDceProduct")
}

model ProductCost {
  id               String   @id @default(cuid())
  productId        String
  name             String
  unitCostCents    Int
  unit             String   // ONE_TIME | MONTH | YEAR | OTHER
  multiplierKind   String   @default("FIXED") // FIXED | PER_QUOTE_ITEM | PER_MONTHS | CUSTOM_JSON
  multiplierValue  Float?   // optional: e.g. 12
  conditionsJson   String?  // JSON string for simple conditions (e.g. {"onlyIf":{"scontoCrmAnnuale":true}})
  active           Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model RoiConfig {
  id                    String   @id
  defaultPreventiviMese Float    @default(4)
  defaultImportoMedio   Float    @default(5000)
  defaultConversione    Float    @default(25)
  defaultMargine        Float    @default(20)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Quote {
  id                    String      @id @default(cuid())
  quoteNumber           String      @unique
  publicPdfToken        String?
  userId                String
  dceProductId          String?
  clientName            String
  clientCompany         String?
  clientEmail           String?
  clientPhone           String?
  clientNotes           String?
  crmCustomerId         String?
  clientAddress         String?
  clientPostalCode      String?
  clientCity            String?
  clientProvince        String?
  originCliente         String?
  estrattoDiagnosi      String?
  diagnosiGiaPagata     Boolean     @default(true)
  roiPreventiviMese     Float?
  roiImportoMedio       Float?
  roiConversioneAttuale Float?
  roiMargineCommessa    Float?
  roiSnapshot           String?
  clientVat             String?
  clientSdi             String?
  totalSetup            Int
  totalMonthly          Int
  totalAnnual           Int
  costSetup             Int         @default(0)
  costMonthly           Int         @default(0)
  costAnnual            Int         @default(0)
  marginAnnual          Int         @default(0)
  marginPercentAnnual   Float       @default(0) // 0..100
  salesStage            String      @default("open") // open | won | lost
  deliveryStage         String      @default("not_started") // not_started | in_progress | done
  wonAt                 DateTime?
  kickoffAt             DateTime?
  closedAt              DateTime?
  deliveryExpectedAt    DateTime?
  depositPercent        Int         @default(30)
  setupBeforeDiscount   Int         @default(0)
  discountType          String?
  discountAmount        Int         @default(0)
  discountCode          String?
  discountPercent       Int         @default(0)
  scontoCrmAnnuale      Boolean     @default(true)
  scontoAiVocaleAnnuale Boolean     @default(false)
  scontoWaAnnuale       Boolean     @default(false)
  voucherAuditApplied   Boolean     @default(false)
  // Tipo del preventivo:
  //  - STANDARD: composto dal listino (workflow QuoteEditor + PDF + invio)
  //  - MANUAL:   composto a voci libere fuori dal listino (no PDF/email)
  kind                  String      @default("STANDARD")
  status                String      @default("draft")
  sentAt                DateTime?
  viewedAt              DateTime?
  expiresAt             DateTime?
  notes                 String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  dceProduct            Product?    @relation("QuoteDceProduct", fields: [dceProductId], references: [id])
  user                  User        @relation(fields: [userId], references: [id])
  items                 QuoteItem[]
  payments              QuotePayment[]
  adjustments           QuoteAdjustment[]
}

model QuoteItem {
  id          String   @id @default(cuid())
  quoteId     String
  productCode String
  productName String
  price       Int
  quantity    Int      @default(1)
  isMonthly   Boolean  @default(false)
  // true = riga "manuale" (descrizione+importo libero, fuori listino).
  // false = riga proveniente dal listino standard (Product.code).
  isCustom    Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  costs       QuoteItemCost[]
}

model QuoteItemCost {
  id             String   @id @default(cuid())
  quoteItemId    String
  productCostId  String?  // optional link back to listino row
  name           String
  unitCostCents  Int
  unit           String
  multiplier     Float    @default(1)
  lineCostCents  Int
  createdAt      DateTime @default(now())
  quoteItem      QuoteItem @relation(fields: [quoteItemId], references: [id], onDelete: Cascade)

  @@index([quoteItemId])
}

model QuotePayment {
  id        String   @id @default(cuid())
  quoteId   String
  amount    Int
  dueDate   DateTime?
  paidAt    DateTime?
  method    String?
  notes     String?
  kind      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

model QuoteAdjustment {
  id         String   @id @default(cuid())
  quoteId    String
  label      String
  kind       String   // revenue | cost
  amount     Int      // cents
  frequency  String   @default("ONE_TIME") // ONE_TIME | MONTH | YEAR
  startsAt   DateTime?
  endsAt     DateTime?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  quote      Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

model DiscountCode {
  id              String    @id @default(cuid())
  code            String    @unique
  description     String?
  discountPercent Int       @default(0)
  discountAmount  Int       @default(0)
  maxUses         Int?
  usedCount       Int       @default(0)
  expiresAt       DateTime?
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
